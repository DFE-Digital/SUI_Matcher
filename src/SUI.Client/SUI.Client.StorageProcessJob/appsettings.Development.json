{
  "AzureWebJobsStorage": "UseDevelopmentStorage=true",
  "QueueName": "storage-process-job",
  "PersonMatching": {
    "SearchStrategy": "strategy4",
    "StrategyVersion": 2
  },
  "StorageProcessJob": {
    "QueueName": "storage-process-job",
    "ProcessedContainerName": "processed",
    "SuccessContainerName": "success",
    "MaxDequeueCount": 1,
    "MessageVisibilityTimeoutMinutes": 10,
    "MessageVisibilityRenewalIntervalMinutes": 5,
    "MatchApiBaseAddress": "http://localhost:5000"
  },
  "CsvMatchData": {
    "DateFormat": "yyyy-MM-dd",
    "ColumnMappings": {
      "Id": "Id",
      "Given": "GivenName",
      "Family": "FamilyName",
      "BirthDate": "DOB",
      "Email": "EMAIL",
      "Postcode": "POSTCODE",
      "Gender": "GENDER",
      "Phone": "PHONE",
      "NhsNumber": "NHS_NUMBER"
    }
  }
}
